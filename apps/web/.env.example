# Cloudflare Workers signaling endpoint (wss://...)
VITE_SIGNAL_URL=wss://amida-signal.<your-subdomain>.workers.dev

# STUN server URL used by WebRTC
VITE_STUN_URL=stun:stun.l.google.com:19302

# Optional: URL to wasm-pack generated JS entry (ladder_core.js)
# If not set, app falls back to TypeScript host logic.
# Example (local dev):
# VITE_WASM_JS_URL=/crates/ladder-core/pkg/ladder_core.js

# GitHub Pages base path (repo name)
# Example: /ami-da/
VITE_BASE_PATH=/

# Vite dev server port
VITE_DEV_PORT=5173
